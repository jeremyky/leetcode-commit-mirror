# Optional: only needed if using direct API mode (not recommended).
# The Playwright browser export mode handles auth automatically.
#
# To get these values:
# 1. Go to https://leetcode.com and log in
# 2. Open DevTools > Application > Cookies > https://leetcode.com
# 3. Copy the values for LEETCODE_SESSION and csrftoken
LEETCODE_SESSION=
LEETCODE_CSRFTOKEN=
